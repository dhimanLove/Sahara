# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ─── Google Gemini (client-side, used on /demo page) ─────────────────────────
# Get this from: https://aistudio.google.com/app/apikey
# IMPORTANT: Add as VITE_ prefix so Vite exposes it to the browser bundle

VITE_GEMINI_API_KEY=your-gemini-api-key

# ─── Lovable AI Gateway (server-side, used in server functions) ───────────────
# Get this from: your Lovable workspace settings → AI credentials
# NOTE: No VITE_ prefix — this is server-only, never exposed to the browser

LOVABLE_API_KEY=your-lovable-api-key
